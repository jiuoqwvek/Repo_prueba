# ──── Variables de configuración central ────
# Copia este archivo a .env en la raíz del proyecto y completa los valores.
#   cp .env.example .env
# Luego levanta los servicios con:
#   docker compose up --build -d

# ──── Modelo LLM (backend) ────
# GITHUB_TOKEN    → Token de GitHub Models (https://github.com/settings/tokens)
# OPENAI_BASE_URL → Endpoint del proveedor (GitHub Models / OpenAI / Azure)
# AGENT_MODEL     → Nombre del modelo a usar
GITHUB_TOKEN=""
OPENAI_BASE_URL="https://models.inference.ai.azure.com"
AGENT_MODEL="gpt-4o-mini"

# ──── SMTP (correos de confirmación de órdenes) ────
# Usa una contraseña de aplicación de Google si tienes 2FA activado:
#   https://myaccount.google.com/apppasswords
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT="587"
SMTP_FROM_EMAIL="tu-correo@gmail.com"
SMTP_PASSWORD="tu-contraseña-app"
ADMIN_EMAIL="admin@dominio.com"

# ──── Backend ────
BACKEND_URL="http://backend:8000"

# ──── Observabilidad (opcional) ────
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="ingenieria_soluciones_con_ia"
