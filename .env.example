# Configuración SMTP para Gmail
SMTP_FROM_EMAIL={tu_correo_que_envia_el_mensaje}
SMTP_PASSWORD={tu_contraseña_de_aplicacion}
ADMIN_EMAIL={tu_correo_que_recibe_las_notificaciones}

# INSTRUCCIONES:
# 1. Genera contraseña de app en: https://myaccount.google.com/apppasswords
# 2. Reemplaza los valores entre {} con tus datos reales
# 3. Guarda como .env (sin las llaves {})
# IMPORTANTE: .env esta en .gitignore, no se sube a GitHub

